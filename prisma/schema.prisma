model User {
  id                  Int         @id @default(autoincrement())
  name                String
  email               String
  emailVerified       Boolean     @default(false) @map("email_verified")
  image               String?
  profile             Profile?
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt  @map("updated_at")
  role                String?
  banned              Boolean?    @default(false)
  banReason           String?     @map("ban_reason")
  banExpires          DateTime?   @map("ban_expires")
  username            String?
  displayUsername     String?     @map("display_name")
  twoFactorEnabled    Boolean?    @default(false) @map("two_factor_enabled")
  lastLoginMethod     String?     @map("last_login_method")
  phoneNumber         String?     @map("phone_number")
  phoneNumberVerified Boolean?    @map("phone_number_verified")
  roleId              Int?        @map("role_id")     
  // 2. FIX: Rename this relation tracker field to bypass Better-Auth's 'role' collision
  profileComplete     Boolean?    @default(false) @map("profile_complete")
  isLinked            Boolean?    @default(false) @map("is_linked")
  mustChangePassword  Boolean?    @default(false) @map("must_change_password")
  userRole            Role?       @relation(fields: [roleId], references: [id])
  isEnabled           Boolean?    @default(true)  @map("is_enabled")
  isLocked            Boolean?    @default(false) @map("is_locked")
  isActivated         Boolean?    @default(false) @map("is_activated")
  deletedAt           String?     @map("deleted_at")
  createdBy           Int?        @map("created_by")
  updatedBy           Int?        @map("updated_by")
  objectVersionId     Int?        @default(1)
  sessions            Session[]
  accounts            Account[]
  twofactors          TwoFactor[]
  passkeys            Passkey[]

  // Audit and Tracking
  auditTrail AuditTrail[]

  @@unique([email])
  @@unique([username])
  @@unique([phoneNumber])
  @@map("user")
}

model Session {
  id             Int      @id @default(autoincrement())
  expiresAt      DateTime @map("expires_at")
  token          String   
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt  @map("updated_by")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  userId         Int      @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?  @map("impersonated_by")

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    Int       @id @default(autoincrement())
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                Int       @map("user_id")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt  @map("updated_at")

  @@unique([providerId, accountId]) // ✅ Add this to fix the upscale upsert and lookups
  @@index([userId])
  @@map("account")
}

model Verification {
  id         Int      @id @default(autoincrement())
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt  @map("updated_at")

  @@index([identifier])
  @@map("verification")
}

model Apikey {
  id                  Int       @id @default(autoincrement())
  configId            String    @default("default") @map("config_id")
  name                String?
  start               String?
  referenceId         String    @map("reference_id")
  prefix              String?
  key                 String
  refillInterval      Int?      @map("refill_interval")
  refillAmount        Int?      @map("refill_amount")
  lastRefillAt        DateTime? @map("last_refill_at")
  enabled             Boolean?  @default(true)
  rateLimitEnabled    Boolean?  @default(true)  @map("rate_limit_enabled")
  rateLimitTimeWindow Int?      @default(86400000)  @map("rate_limit_time_window")
  rateLimitMax        Int?      @default(10)  @map("rate_limit_max")
  requestCount        Int?      @default(0)   @map("request_count")
  remaining           Int?
  lastRequest         DateTime? @map("last_request")
  expiresAt           DateTime? @map("expires_at")
  createdAt           DateTime  @map("created_at")
  updatedAt           DateTime  @map("updated_at")
  permissions         String?
  metadata            String?

  @@index([configId])
  @@index([referenceId])
  @@index([key])
  @@map("apikey")
}

model TwoFactor {
  id          Int      @id @default(autoincrement())
  secret      String
  backupCodes String    @map("backup_codes")
  userId      Int       @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verified    Boolean? @default(true)

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}

model Passkey {
  id           Int       @id @default(autoincrement())
  name         String?
  publicKey    String   @map("public_key")
  userId       Int      @map("user_id")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialID String   @map("credential_id")
  counter      Int
  deviceType   String   @map("device_type")
  backedUp     Boolean  @map("backed_up")
  transports   String?  
  createdAt    DateTime?  @map("created_at")
  aaguid       String?

  @@index([userId])
  @@index([credentialID])
  @@map("passkey")
}

model Jwks {
  id         Int       @id @default(autoincrement())
  publicKey  String   @map("public_key")
  privateKey String   @map("private_key")
  createdAt  DateTime @map("created_at")
  expiresAt  DateTime?  @map("expires_at")

  @@map("jwks")
}

model Profile {
  id          Int      @id @default(autoincrement())
  officialId  String   @unique @db.VarChar(10) @map("official_id")
  nationalId  String?  @unique @db.VarChar(10) @map("national_id")
  firstName   String    @db.VarChar(50) @map("first_name")
  lastName    String   @db.VarChar(50) @map("last_name") 
  sex         Sex
  dob         DateTime
  pob         String?  @db.VarChar(50)
  nationality String?  @db.VarChar(100)
  phone       String?  @db.VarChar(255)
  email       String?  @db.VarChar(255)
  address     String?  @db.VarChar(255)
  married     Boolean  @default(false)
  bio         String?

  //--------------------------------------
  // Civil Service
  //--------------------------------------

  // --- Advanced Employment & Civil Service Tracking ---
  status             EmploymentStatus @default(ACTIVE)
  entryDate          DateTime         @map("entry_date") @db.Date // Date they officially entered government service
  retirementAge      Int              @default(60) @map("retirement_age") // Allows overrides (60, 62, 65) based on framework
  expectedRetireDate DateTime?        @map("expected_retire_date") @db.Date
  actualRetireDate   DateTime?        @map("actual_retire_date") @db.Date // Populated when status changes to RETIRED

  //--------------------------------------
  // Current assignment shortcut
  //--------------------------------------

  currentEmploymentId Int? @map("current_employment_id") 

  //--------------------------------------

  Employments EmploymentHistory[]

  CurrentEmployment EmploymentHistory? @relation("CurrentEmployment", fields: [currentEmploymentId], references: [id])

  userId Int? @unique @map("user_id")
  // Cashier    Cashier?

  // Tracking
  isEnabled       Boolean  @default(true) @map("is_enabled")
  isHold          Boolean  @default(false) @map("hold_flag")
  createdBy       Int      @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedBy       Int      @map("updated_by")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  objectVersionId Int      @default(1) @map("object_version_id")

  // Relationships
  User User? @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  // DepartmentHistories DepartmentHistory[]
  // WorkRecords WorkRecord[] // Chronological deployment history across ministries/departments

  @@index([status])
  @@index([entryDate])
  @@index([dob]) // Crucial for calculating retirement forecasts quickly
  @@index([expectedRetireDate])
  @@index([actualRetireDate])
  @@map("profiles")
}

model Ministry {
  id        Int     @id @default(autoincrement())
  code      String  @unique @db.VarChar(20) // e.g., "MCS", "MEF", "MoEYS"
  // nameKhmer   String  @map("name_khmer") @db.VarChar(255) // e.g., ក្រសួងមុខងារសាធារណៈ
  // nameEnglish String  @map("name_english") @db.VarChar(255) // e.g., Ministry of Civil Service
  isEnabled Boolean @default(true) @map("is_enabled")

  // Tracking
  createdBy Int      @map("created_by")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  // Relationships
  Versions    MinistryVersion[]
  Departments Department[]
  // WorkRecords WorkRecord[]

  @@map("ministries")
}

model MinistryVersion {
  id                  Int                 @id @default(autoincrement())
  ministryId          Int @map("ministry_id") 
  code                String              @db.VarChar(20)
  nameKh              String              @db.VarChar(255) @map("name_kh")
  nameEn              String              @db.VarChar(255)  @map("name_en")
  shortName           String?             @db.VarChar(100)  @map("short_name")
  effectiveFrom       DateTime            @db.Date  @map("effective_from")
  effectiveTo         DateTime?           @db.Date  @map("effective_to")
  Ministry            Ministry            @relation(fields: [ministryId], references: [id])
  DepartmentVersions  DepartmentVersion[]
  EmploymentHistories EmploymentHistory[]

  @@index([ministryId, effectiveTo])
  @@map("ministry_versions")
}

model Department {
  id        Int     @id @default(autoincrement())
  // ministryId Int     @map("ministry_id") // Every department explicitly belongs to a Ministry
  code      String  @unique @db.VarChar(20) // Stable immutable key (e.g., "M_CIVIL_SERV_01")
  isEnabled Boolean @default(true) @map("is_enabled")

  // Tracking
  createdBy Int      @map("created_by")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  // Relationships
  // Versions    DepartmentVersion[]
  // Histories   DepartmentHistory[]
  // Ministry    Ministry            @relation(fields: [ministryId], references: [id], onDelete: Restrict)
  Versions DepartmentVersion[]
  // WorkRecords WorkRecord[] // Tracks historical assignments to this department

  // Documents model can safely link here: Documents Document[]
  ministries Ministry[]

  @@map("departments")
}

model DepartmentVersion {
  id                Int @id @default(autoincrement())
  departmentId      Int @map("department_id")
  ministryVersionId Int @map("ministry_version_id")

  parentVersionId Int?   @map("parent_version_id")
  // name         String @db.VarChar(150) // Snapshot of name
  // parentId     Int?   @map("parent_id") // Snapshot of tree location
  code            String @db.VarChar(20)

  nameKh String @map("name_kh") @db.VarChar(255)

  nameEn String @map("name_en") @db.VarChar(255)

  shortName String? @map("short_name") @db.VarChar(100)

  hierarchyLevel Int? @map("hierarchy_level")

  displayOrder Int? @map("display_order")

  // Period this specific configuration/name was active
  effectiveFrom DateTime  @map("effective_from") @db.Timestamp(6)
  effectiveTo   DateTime? @map("effective_to") @db.Timestamp(6) // Null means current active name

  createdBy Int      @map("created_by")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  Department      Department      @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  MinistryVersion MinistryVersion @relation(fields: [ministryVersionId], references: [id])

  Parent DepartmentVersion? @relation("DepartmentTree", fields: [parentVersionId], references: [id])

  Children DepartmentVersion[] @relation("DepartmentTree")

  Employments EmploymentHistory[]

  OutgoingTransitions DepartmentTransition[] @relation("TransitionFrom")

  IncomingTransitions DepartmentTransition[] @relation("TransitionTo")

  @@index([departmentId, effectiveTo])
  @@map("department_versions")
}

model DepartmentTransition {
  id Int @id @default(autoincrement())

  fromDepartmentVersionId Int @map("from_department_version_id")

  toDepartmentVersionId Int @map("to_department_version_id")

  type OrganizationChangeType

  effectiveDate DateTime @db.Date @map("effective_date")

  note String?

  From DepartmentVersion @relation("TransitionFrom", fields: [fromDepartmentVersionId], references: [id])

  To DepartmentVersion @relation("TransitionTo", fields: [toDepartmentVersionId], references: [id])

  @@index([fromDepartmentVersionId])
  @@index([toDepartmentVersionId])
  @@map("department_transitions")
}

model EmploymentHistory {
  id Int @id @default(autoincrement())

  profileId Int @map("profile_id")

  ministryVersionId Int @map("ministry_version_id")

  departmentVersionId Int @map("department_version_id")

  //--------------------------------

  assignmentType AssignmentType @map("assignment_type")

  status EmploymentStatus

  //--------------------------------

  startDate DateTime @db.Date @map("start_date")

  endDate DateTime? @db.Date  @map("end_date")

  //--------------------------------

  positionTitle String? @db.VarChar(150)  @map("position_title")

  rank String? @db.VarChar(100)

  salaryGrade String? @db.VarChar(50) @map("salary_grade")

  salaryStep String? @db.VarChar(50) @map("salary_step")

  //--------------------------------

  decreeNumber String? @db.VarChar(100) @map("decree_number")

  decreeDate DateTime? @db.Date @map("decree_date")

  //--------------------------------

  note String?

  //--------------------------------

  Profile Profile @relation(fields: [profileId], references: [id])

  MinistryVersion MinistryVersion @relation(fields: [ministryVersionId], references: [id])

  DepartmentVersion DepartmentVersion @relation(fields: [departmentVersionId], references: [id])
  profiles          Profile[]         @relation("CurrentEmployment")

  @@index([profileId, endDate])
  @@index([departmentVersionId])
  @@index([ministryVersionId])
  @@map("employment_histories")
}

