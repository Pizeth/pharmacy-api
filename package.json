{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "pharmacy-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "type": "commonjs",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest build --webpack --webpackPath webpack-hmr.config.cjs --watch",
    "db:reset": "prisma migrate reset",
    "db:seed": "tsx prisma/seed.ts --seed",
    "db:seed:dev": "tsx --watch prisma/seed.ts --seed",
    "db:clear": "tsx prisma/seed.ts --clear",
    "db:full-reset": "npm run db:clear && npm run db:reset",
    "build:webpack": "tsc webpack-hmr.config.ts --outDir ./dist",
    "start:dev1": "npm run build:webpack && nest start --webpack --webpackPath ./dist/webpack-hmr.config.js --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.cjs",
    "lint": "eslint . --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "generate:dicebear": "tsx scripts/generate-dicebear.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts --seed"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1069.0",
    "@aws-sdk/s3-request-presigner": "^3.1069.0",
    "@better-auth/api-key": "^1.6.19",
    "@better-auth/i18n": "^1.6.19",
    "@better-auth/passkey": "^1.6.19",
    "@better-auth/utils": "^0.4.2",
    "@casl/ability": "^7.0.0",
    "@dicebear/converter": "^10.3.0",
    "@dicebear/core": "^10.3.0",
    "@dicebear/styles": "^10.2.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@thallesp/nestjs-better-auth": "^2.6.1",
    "axios": "^1.18.0",
    "bcrypt": "^6.0.0",
    "better-auth": "^1.6.19",
    "cbor": "^10.0.12",
    "clamscan": "^2.4.0",
    "farmhash": "^5.0.1",
    "form-data": "^4.0.6",
    "http-status-codes": "^2.3.0",
    "lru-cache": "^11.5.1",
    "luxon": "^3.7.2",
    "nanoid": "^5.1.11",
    "nestjs-cls": "^6.2.1",
    "nestjs-i18n": "^10.8.4",
    "nestjs-zod": "^5.4.0",
    "nodemailer": "^9.0.0",
    "openid-client": "^6.8.4",
    "passport": "^0.7.0",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tsx": "^4.22.4",
    "ua-parser-js": "^2.0.10",
    "uuid": "^14.0.0",
    "zod": "^4.4.3",
    "zod-openapi": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.41",
    "@types/bcrypt": "^6.0.0",
    "@types/clamscan": "^2.4.1",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/form-data": "^2.5.2",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.3",
    "@types/nodemailer": "^8.0.1",
    "@types/passport": "^1.0.17",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "@types/webpack-node-externals": "^3.0.4",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "run-script-webpack-plugin": "^0.2.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "webpack": "^5.107.2",
    "webpack-node-externals": "^3.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
